{
  "name": "wasteland",
  "version": "0.1.0",
  "private": true,
  "description": "A web-based save editor for Fallout Shelter",
  "author": "Zander Lewis <zander@zanderlewis.dev>",
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "build": "tsc && vp build",
