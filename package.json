    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.2",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^25.6.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.10",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.18",
    "vite-plus": "^0.1.18"
  },
  "packageManager": "pnpm@10.33.0"
